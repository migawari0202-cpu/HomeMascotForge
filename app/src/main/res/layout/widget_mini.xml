<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_mini"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#33000000"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- 吹き出しエリア（上部・高さ自動） -->
    <FrameLayout
        android:id="@+id/speech_bubble_area_mini"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/speech_bubble_bg"
        android:padding="8dp">

        <TextView
            android:id="@+id/widget_speech_mini"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="セリフ読み込み中.."
            android:textColor="#333333"
            android:textSize="10sp"
            android:lineSpacingExtra="1dp"
            android:ellipsize="end" />
    </FrameLayout>

    <!-- キャラクター画像エリア（残りの高さ全部） -->
    <FrameLayout
        android:id="@+id/character_area_mini"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:layout_marginTop="4dp">

        <!-- キャラクター画像 -->
        <ImageView
            android:id="@+id/widget_character_image_mini"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="bottom|center_horizontal"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:contentDescription="キャラクター画像" />
    </FrameLayout>

</LinearLayout>