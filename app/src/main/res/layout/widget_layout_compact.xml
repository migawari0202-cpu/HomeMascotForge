<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_compact"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#33000000">

    <!-- メインエリア（全体に広がる） -->
    <LinearLayout
        android:id="@+id/main_content_area_compact"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentTop="true"
        android:layout_toEndOf="@+id/widget_bottom_bar_compact"
        android:orientation="vertical"
        android:padding="4dp">

        <!-- 吹き出しエリア -->
        <FrameLayout
            android:id="@+id/speech_bubble_area_compact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@drawable/speech_bubble_bg"
            android:padding="9dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- セリフ表示 -->
                <TextView
                    android:id="@+id/widget_speech_compact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="セリフ読み込み中.."
                    android:textColor="#333333"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="3"
                    android:ellipsize="end"
                    android:minLines="3" />

                <!-- デバッグ情報 -->
                <TextView
                    android:id="@+id/text_debug_compact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#999999"
                    android:textSize="9sp"
                    android:visibility="gone" />

            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/other_widget_area_compact"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="bottom|center_horizontal"
            android:padding="0dp">

            <!-- キャラクター画像 -->
            <ImageView
                android:id="@+id/widget_character_image_compact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:scaleType="fitEnd"
                android:adjustViewBounds="true"
                android:contentDescription="キャラクター画像" />
        </LinearLayout>
    </LinearLayout>

    <!-- 縦向きバー（FrameLayout でラップ） -->
    <FrameLayout
        android:id="@+id/widget_bottom_bar_compact"
        android:layout_width="65dp"
        android:layout_height="match_parent"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:clipToOutline="true"
        android:background="#AA000000">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:weightSum="4"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <!-- バッテリーエリア -->
            <LinearLayout
                android:id="@+id/battery_area_compact"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="2dp">

                <ImageView
                    android:id="@+id/widget_battery_icon_compact"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginBottom="2dp"
                    android:contentDescription="バッテリーアイコン" />

                <TextView
                    android:id="@+id/widget_battery_percent_compact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- ゲームボタン -->
            <LinearLayout
                android:id="@+id/game_button_compact"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/game_b"
                    android:contentDescription="ゲームボタン"/>
            </LinearLayout>

            <!-- 天気エリア -->
            <LinearLayout
                android:id="@+id/weather_area_compact"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="2dp">

                <TextView
                    android:id="@+id/weather_icon_compact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☀️"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/weather_temp_compact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25℃"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- メモボタン -->
            <LinearLayout
                android:id="@+id/memo_button_compact"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/button_bg_normal"
                    android:contentDescription="メモボタン"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- 🍀 追加：時計（右下固定） -->
    <ImageView
        android:id="@+id/widget_clock_compact"
        android:layout_width="115dp"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:scaleType="centerInside"
        android:contentDescription="時計" />

</RelativeLayout>
